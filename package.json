{
  "name": "claude-session-driver",
  "version": "4.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist:check": "pnpm build && git diff --exit-code dist/",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@types/node": "^22.19.13",
    "lefthook": "^2.1.8",
    "smol-toml": "^1.6.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
